{
  "common": {
    "timeoutSec": 15,
    "snapshotFolder": "./data/snapshots",
    "caseSensitive": false,
    "regexesForRemoval": [
      {
        "pattern": "<script\\b[^>]*>.*?<\\/script>",
        "replacement": "",
        "multiline": true,
        "singleline": true,
        "description": "Remove all script tags and their content"
      },
      {
        "pattern": "<style\\b[^>]*>.*?<\\/style>",
        "replacement": "",
        "multiline": true,
        "singleline": true,
        "description": "Remove all style tags and their content"
      },
      {
        "pattern": "<!--.*?-->",
        "replacement": "",
        "multiline": true,
        "singleline": true,
        "description": "Remove all HTML comments"
      }
    ]
  },
  "pages": [
    {
      "name": "Example",
      "url": "https://example.com",
      "keywords": [
        "example",
        "domain",
        "illustrative"
      ]
    }
  ]
}