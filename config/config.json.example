{
  "fetcher": {
    "timeoutSec": 20,
    "pages": [
      {
        "name": "Example",
        "url": "https://example.com",
        "keywords": [
          "example",
          "domain",
          "illustrative"
        ]
      },
      {
        "name": "BBC News",
        "url": "https://www.bbc.com/news",
        "keywords": [
          "breaking",
          "world",
          "politics",
          "economy"
        ]
      },
      {
        "name": "Hacker News",
        "url": "https://news.ycombinator.com",
        "keywords": [
          "startup",
          "AI",
          "programming",
          "security"
        ]
      }
    ],
    "regexesForRemoval": [
      {
        "pattern": "<script\\b[^>]*>.*?<\\/script>",
        "replacement": "",
        "multiline": true,
        "singleline": true,
        "description": "Remove all script tags and their content"
      },
      {
        "pattern": "<style\\b[^>]*>.*?<\\/style>",
        "replacement": "",
        "multiline": true,
        "singleline": true,
        "description": "Remove all style tags and their content"
      },
      {
        "pattern": "<!--.*?-->",
        "replacement": "",
        "multiline": true,
        "singleline": true,
        "description": "Remove all HTML comments"
      }
    ]
  },
  "matcher": {
    "caseSensitive": false
  },
  "scheduler": {
    "notifyOnHashChange": true,
    "checkIntervalSec": 30,
    "startTime": "08:00",
    "endTime": "22:00"
  },
  "email": {
    "emailEnabled": false,
    "smtp_server": "smtp.gmail.com",
    "port": 465,
    "sender": "monitor@yourdomain.com",
    "recipient": "alerts@yourdomain.com",
    "subject": "Web Monitor Alert"
  },
  "logging": {
    "level": "INFO",
    "file": "./logs/webmonitor.log",
    "console": true
  }
}